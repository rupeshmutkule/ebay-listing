<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title><%= title %></title>
<style>
  body { font-family: Arial, sans-serif; margin: 24px; background: #f7f7f8; color: #222; }
  h1 { font-size: 20px; }
  .toolbar { display: flex; gap: 10px; flex-wrap: wrap; margin: 16px 0; }
  button { padding: 10px 16px; border: none; border-radius: 6px; background: #0654ba; color: #fff; cursor: pointer; font-size: 14px; }
  button:hover { background: #054098; }
  button.secondary { background: #444; }
  .danger { background: #b00020; }
  textarea { width: 100%; height: 60px; margin: 8px 0; font-family: monospace; }
  table { border-collapse: collapse; width: 100%; background: #fff; margin-top: 10px; }
  th, td { border: 1px solid #ddd; padding: 6px 8px; font-size: 13px; text-align: left; }
  th { background: #eee; }
  img.thumb { width: 40px; height: 40px; object-fit: cover; }
  .status { font-size: 13px; margin: 8px 0; white-space: pre-wrap; }
  .ok { color: green; } .bad { color: #b00020; }
</style>
</head>
<body>

<h1><%= title %></h1>

<div class="toolbar">
  <button id="btnFetch">1. Fetch products from Seller A</button>
  <button id="btnMigrate" class="danger">2. Migrate selected to Seller B (removes from A)</button>
  <button id="btnViewB" class="secondary">3. View products live on Seller B</button>
</div>

<div>
  <label>Or paste specific SKUs (comma or newline separated) instead of using checkboxes:</label>
  <textarea id="manualSkus" placeholder="SKU001, SKU002, SKU003"></textarea>
</div>

<div class="status" id="statusBox"></div>
<div id="tableWrap"></div>

<hr style="margin: 24px 0;">
<h2 style="font-size:16px;">Seller B cleanup (for stuck/duplicate test listings)</h2>
<div style="display:flex; gap:8px; margin-top:6px;">
  <input id="deleteSkuInput" placeholder="SKU to remove from Seller B" style="flex:1; padding:8px;">
  <button id="btnDeleteB" class="danger">Remove from Seller B</button>
</div>

<script>
const statusBox = document.getElementById('statusBox');
const tableWrap = document.getElementById('tableWrap');
const manualSkusBox = document.getElementById('manualSkus');

function log(msg, isError) {
  const line = document.createElement('div');
  line.textContent = msg;
  line.className = isError ? 'bad' : 'ok';
  statusBox.prepend(line);
}

function getManualSkus() {
  return manualSkusBox.value.split(/[\n,]/).map(s => s.trim()).filter(Boolean);
}

function getCheckedSkus() {
  return Array.from(document.querySelectorAll('.row-check:checked')).map(cb => cb.dataset.sku);
}

function getSelectedSkus() {
  const manual = getManualSkus();
  return manual.length ? manual : getCheckedSkus();
}

async function callApi(url, options) {
  const res = await fetch(url, options);
  const data = await res.json();
  if (!res.ok) throw new Error(data.error ? JSON.stringify(data.error) : 'Request failed');
  return data;
}

function renderTable(products) {
  const rows = products.map(p => `
    <tr>
      <td><input type="checkbox" class="row-check" data-sku="${p.sku}"></td>
      <td>${p.image ? `<img class="thumb" src="${p.image}">` : ''}</td>
      <td>${p.sku}</td>
      <td>${p.title}</td>
      <td>${p.quantity}</td>
      <td>${p.condition}</td>
    </tr>
  `).join('');

  tableWrap.innerHTML = `
    <p><label><input type="checkbox" id="checkAll"> select all (${products.length})</label></p>
    <table>
      <thead><tr><th></th><th>Image</th><th>SKU</th><th>Title</th><th>Qty</th><th>Condition</th></tr></thead>
      <tbody>${rows}</tbody>
    </table>
  `;

  document.getElementById('checkAll').onchange = (e) => {
    document.querySelectorAll('.row-check').forEach(cb => cb.checked = e.target.checked);
  };
}

// ---------- BUTTON 1: Fetch from Seller A ----------
document.getElementById('btnFetch').onclick = async () => {
  log('Fetching products from Seller A...');
  try {
    const data = await callApi('/api/seller-a/products');
    log(`Found ${data.count} products on Seller A`);
    renderTable(data.products);
  } catch (err) {
    log('Fetch failed: ' + err.message, true);
  }
};

// ---------- BUTTON 2: Migrate selected to Seller B ----------
document.getElementById('btnMigrate').onclick = async () => {
  const skus = getSelectedSkus();
  if (!skus.length) return log('Select products (or paste SKUs) first.', true);
  if (!confirm(`Migrate ${skus.length} product(s) to Seller B and remove them from Seller A?`)) return;
  log(`Migrating ${skus.length} product(s) to Seller B...`);
  try {
    const data = await callApi('/api/migrate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ skus })
    });
    log(`Migration done: ${data.succeeded} succeeded, ${data.failed} failed`);
    data.results.forEach(r => {
      if (r.success) {
        log(`  ${r.sku}: live on B (listing ${r.listingId || r.offerId}), removed from A: ${r.removedFromA}`);
      } else {
        log(`  ${r.sku}: FAILED — ${JSON.stringify(r.error)}`, true);
      }
    });
  } catch (err) {
    log('Migration failed: ' + err.message, true);
  }
};

// ---------- BUTTON 3: View products live on Seller B ----------
document.getElementById('btnViewB').onclick = async () => {
  log('Fetching products from Seller B...');
  try {
    const data = await callApi('/api/seller-b/products');
    log(`Found ${data.count} products on Seller B`);
    renderTable(data.products);
  } catch (err) {
    log('Fetch failed: ' + err.message, true);
  }
};

// ---------- Cleanup: remove one SKU from Seller B ----------
document.getElementById('btnDeleteB').onclick = async () => {
  const sku = document.getElementById('deleteSkuInput').value.trim();
  if (!sku) return log('Type a SKU to remove first.', true);
  if (!confirm(`Withdraw and delete "${sku}" from Seller B?`)) return;
  try {
    await callApi('/api/seller-b/delete', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ sku })
    });
    log(`Removed ${sku} from Seller B`);
  } catch (err) {
    log('Remove failed: ' + err.message, true);
  }
};
</script>
</body>
</html>