<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title><%= title %></title>
<style>
  body { font-family: Arial, sans-serif; margin: 24px; background: #f7f7f8; color: #222; }
  h1 { font-size: 20px; }
  .toolbar { display: flex; gap: 10px; flex-wrap: wrap; margin: 16px 0; }
  button { padding: 10px 16px; border: none; border-radius: 6px; background: #0654ba; color: #fff; cursor: pointer; font-size: 14px; }
  button:hover { background: #054098; }
  button.secondary { background: #444; }
  .danger { background: #b00020; }
  textarea { width: 100%; height: 60px; margin: 8px 0; font-family: monospace; }
  table { border-collapse: collapse; width: 100%; background: #fff; margin-top: 10px; }
  th, td { border: 1px solid #ddd; padding: 6px 8px; font-size: 13px; text-align: left; }
  th { background: #eee; }
  img.thumb { width: 40px; height: 40px; object-fit: cover; }
  .status { font-size: 13px; margin: 8px 0; white-space: pre-wrap; max-height: 300px; overflow-y: auto; }
  .ok { color: green; } .bad { color: #b00020; } .warn { color: #a06a00; }
</style>
</head>
<body>
<h1><%= title %></h1>
<p style="font-size:13px;color:#555;">
  Identifiers below are <strong>eBay Item Numbers</strong>. Migration verifies the new listing
  is live on Seller B before removing it from Seller A. Progress is saved to a checkpoint file,
  so re-running the same list skips items already completed.
</p>

<div class="toolbar">
  <button id="btnFetch">1. Fetch products from Seller A</button>
  <button id="btnMigrate" class="danger">2. Migrate selected to Seller B (removes from A)</button>
  <button id="btnViewB" class="secondary">3. View products live on Seller B</button>
  <button id="btnStatus" class="secondary">Check migration progress</button>
</div>

<div>
  <label>Or paste specific Item Numbers (comma or newline separated) instead of using checkboxes:</label>
  <textarea id="manualIds" placeholder="123456789012, 123456789013"></textarea>
</div>

<div class="status" id="statusBox"></div>
<div id="tableWrap"></div>

<script>
const statusBox = document.getElementById('statusBox');
const tableWrap = document.getElementById('tableWrap');
const manualIdsBox = document.getElementById('manualIds');

function log(msg, cls) {
  const line = document.createElement('div');
  line.textContent = msg;
  line.className = cls || 'ok';
  statusBox.prepend(line);
}

function getManualIds() {
  return manualIdsBox.value.split(/[\n,]/).map(s => s.trim()).filter(Boolean);
}

function getCheckedIds() {
  return Array.from(document.querySelectorAll('.row-check:checked')).map(cb => cb.dataset.itemid);
}

function getSelectedIds() {
  const manual = getManualIds();
  return manual.length ? manual : getCheckedIds();
}

async function callApi(url, options) {
  const res = await fetch(url, options);
  const data = await res.json();
  if (!res.ok) throw new Error(data.error ? JSON.stringify(data.error) : 'Request failed');
  return data;
}

function renderTable(products) {
  const rows = products.map(p => `
    <tr>
      <td><input type="checkbox" class="row-check" data-itemid="${p.itemId}"></td>
      <td>${p.image ? `<img class="thumb" src="${p.image}">` : ''}</td>
      <td>${p.itemId}</td>
      <td>${p.sku || ''}</td>
      <td>${p.title}</td>
      <td>${p.quantity}</td>
      <td>${p.status || ''}</td>
    </tr>
  `).join('');
  tableWrap.innerHTML = `
    <p><label><input type="checkbox" id="checkAll"> select all (${products.length})</label></p>
    <table>
      <thead><tr><th></th><th>Image</th><th>Item Number</th><th>SKU</th><th>Title</th><th>Qty</th><th>Status</th></tr></thead>
      <tbody>${rows}</tbody>
    </table>`;
  document.getElementById('checkAll').onchange = (e) => {
    document.querySelectorAll('.row-check').forEach(cb => cb.checked = e.target.checked);
  };
}

document.getElementById('btnFetch').onclick = async () => {
  log('Fetching products from Seller A...');
  try {
    const data = await callApi('/api/seller-a/products');
    log(`Found ${data.count} products on Seller A`);
    renderTable(data.products);
  } catch (err) { log('Fetch failed: ' + err.message, 'bad'); }
};

document.getElementById('btnMigrate').onclick = async () => {
  const itemIds = getSelectedIds();
  if (!itemIds.length) return log('Select products (or paste Item Numbers) first.', 'bad');
  if (!confirm(`Migrate ${itemIds.length} product(s) to Seller B and remove them from Seller A?`)) return;
  log(`Migrating ${itemIds.length} product(s) to Seller B... this can take a while for large batches.`);
  try {
    const data = await callApi('/api/migrate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ itemIds })
    });
    log(`Migration done: ${data.succeeded} succeeded, ${data.failed} failed`);
    data.results.forEach(r => {
      if (r.success) {
        log(`  ${r.itemId}: now live on B as ${r.newItemIdOnB}, removed from A`, 'ok');
      } else {
        log(`  ${r.itemId}: FAILED — ${r.error}`, 'bad');
      }
    });
  } catch (err) { log('Migration failed: ' + err.message, 'bad'); }
};

document.getElementById('btnViewB').onclick = async () => {
  log('Fetching products from Seller B...');
  try {
    const data = await callApi('/api/seller-b/products');
    log(`Found ${data.count} products on Seller B`);
    renderTable(data.products);
  } catch (err) { log('Fetch failed: ' + err.message, 'bad'); }
};

document.getElementById('btnStatus').onclick = async () => {
  try {
    const data = await callApi('/api/migration-status');
    const entries = Object.entries(data.checkpoint);
    log(`Checkpoint has ${entries.length} tracked item(s)`);
    entries.forEach(([itemId, info]) => {
      const cls = info.status === 'removed_from_a' ? 'ok' : info.status === 'failed' ? 'bad' : 'warn';
      log(`  ${itemId}: ${info.status}${info.newItemIdOnB ? ' -> ' + info.newItemIdOnB : ''}`, cls);
    });
  } catch (err) { log('Status check failed: ' + err.message, 'bad'); }
};
</script>
</body>
</html>
